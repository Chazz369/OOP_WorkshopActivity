<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.inventory.app.controller.SignUpController"
           styleClass="login-root"
           prefWidth="1100" prefHeight="700"
           stylesheets="@../css/styles.css">

    <VBox alignment="CENTER" styleClass="login-container" maxWidth="420" maxHeight="640">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>

        <!-- Title -->
        <Label text="Create Account" styleClass="login-title">
            <VBox.margin>
                <Insets top="10"/>
            </VBox.margin>
        </Label>

        <!-- Subtitle -->
        <Label text="Set up your inventory credentials" styleClass="login-subtitle">
            <VBox.margin>
                <Insets bottom="20"/>
            </VBox.margin>
        </Label>

        <!-- Full Name -->
        <Label text="Full Name" styleClass="form-label">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>
        <TextField fx:id="fullNameField" promptText="Full Name" styleClass="form-field">
            <VBox.margin>
                <Insets bottom="10"/>
            </VBox.margin>
        </TextField>

        <!-- Username -->
        <Label text="Username" styleClass="form-label">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>
        <TextField fx:id="usernameField" promptText="Username" styleClass="form-field">
            <VBox.margin>
                <Insets bottom="10"/>
            </VBox.margin>
        </TextField>

        <!-- Password -->
        <Label text="Password" styleClass="form-label">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>
        <PasswordField fx:id="passwordField" promptText="Password" styleClass="form-field">
            <VBox.margin>
                <Insets bottom="10"/>
            </VBox.margin>
        </PasswordField>

        <!-- Confirm Password -->
        <Label text="Confirm Password" styleClass="form-label">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" styleClass="form-field">
            <VBox.margin>
                <Insets bottom="15"/>
            </VBox.margin>
        </PasswordField>

        <!-- Error Label -->
        <Label fx:id="errorLabel" text="" styleClass="error-label" visible="false" managed="false">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>

        <!-- Success Label -->
        <Label fx:id="successLabel" text="" styleClass="success-label" visible="false" managed="false">
            <VBox.margin>
                <Insets bottom="5"/>
            </VBox.margin>
        </Label>

        <!-- Create Account Button -->
        <Button fx:id="signUpButton" text="Create Account" onAction="#handleSignUp"
                styleClass="sign-in-button" maxWidth="Infinity">
            <VBox.margin>
                <Insets bottom="10"/>
            </VBox.margin>
        </Button>

        <!-- Back to Login Link -->
        <Hyperlink text="Already have an account? Sign In" onAction="#handleBackToLogin"
                   styleClass="sign-up-link"/>

        <!-- Loading Indicator -->
        <ProgressIndicator fx:id="loadingIndicator" visible="false" managed="false"
                           prefWidth="30" prefHeight="30"/>
    </VBox>
</StackPane>
